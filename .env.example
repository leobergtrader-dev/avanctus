# Copie este arquivo para ".env" e preencha com o SEU token de API.
# O arquivo .env NUNCA deve ser compartilhado nem enviado pro git (já está no .gitignore).

# Token gerado em: app.avanctus.com -> API -> Criar novo token
API_TOKEN=cole_seu_token_aqui

# Base da API (descoberta lendo o app da Avanctus). Normalmente não precisa mudar.
BASE_URL=https://broker-api.mybrokerdev.com

# Porta local do painel
PORT=3000

# --- Telegram (userbot MTProto, fase de sinais) ---
# Obtenha api_id e api_hash em https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telefone no formato internacional, ex.: +5511999999999
TELEGRAM_PHONE=
# Nome, @usuario ou link do grupo de sinais a monitorar
TELEGRAM_GRUPO=
# Gerada no 1º login (não preencher à mão)
TELEGRAM_SESSION=
